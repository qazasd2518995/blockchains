# ───────────────────────────────────────────────
# 資料庫（PostgreSQL）
# 取得方式：Render Dashboard → PostgreSQL 實例 → Connect → External Database URL
# ⚠️ 永遠不要把真實密碼提交到 git！
# ───────────────────────────────────────────────
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>"

# ───────────────────────────────────────────────
# JWT 設定
# 產生隨機 32 字元密鑰：`openssl rand -hex 32`
# ───────────────────────────────────────────────
JWT_SECRET="change-me-to-a-random-32-byte-hex-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ───────────────────────────────────────────────
# 伺服器
# ───────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS (逗號分隔)
CORS_ORIGIN="http://localhost:5173,http://localhost:4173"

# ───────────────────────────────────────────────
# 遊戲系統
# ───────────────────────────────────────────────
SIGNUP_BONUS=1000
MAX_SINGLE_BET=100000
