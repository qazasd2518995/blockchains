# ───────────────────────────────────────────────
# 資料庫（PostgreSQL）
# 取得方式：Render Dashboard → PostgreSQL 實例 → Connect → External Database URL
# ⚠️ 永遠不要把真實密碼提交到 git！
# ───────────────────────────────────────────────
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>"

# ───────────────────────────────────────────────
# JWT 設定
# 產生隨機 32 字元密鑰：`openssl rand -hex 32`
# ───────────────────────────────────────────────
JWT_SECRET="change-me-to-a-random-32-byte-hex-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ───────────────────────────────────────────────
# 伺服器
# ───────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
# 預設不要開 Prisma query log，否則 production 會被每條 SQL 洗版。
PRISMA_QUERY_LOG=false
SLOW_REQUEST_MS=1000

# CORS (逗號分隔)
# 代理後台：yachiyo168.com / yachiyo188.com；遊戲前台：yachiyo666.com / yachiyo777.com
CORS_ORIGIN="http://localhost:5173,http://localhost:4173,http://localhost:5174,http://localhost:4174,https://www.yachiyo168.com,https://yachiyo168.com,https://www.yachiyo188.com,https://yachiyo188.com,https://www.yachiyo666.com,https://yachiyo666.com,https://www.yachiyo777.com,https://yachiyo777.com"

# 百家樂整合密鑰：八千代後端用它簽 launch token，百家樂後端的 BG_INTEGRATION_SECRET 必須相同。
BACCARAT_INTEGRATION_SECRET="change-me-to-a-shared-32-byte-hex-string"

# ───────────────────────────────────────────────
# 遊戲系統
# ───────────────────────────────────────────────
# 公開註冊已停用。SIGNUP_BONUS 僅用於 /api/admin/members 建立新會員時的初始點數。
SIGNUP_BONUS=1000
MAX_SINGLE_BET=100000

# ───────────────────────────────────────────────
# 代理後台 Super Admin（seed-agent 使用）
# 密碼至少 12 字元；seed 後永遠不進 git。更換密碼請重跑 seed:agent 或在後台直接改。
# ───────────────────────────────────────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD="change-me-at-least-12-chars"
