// Prisma schema — 加密博彩遊戲平台
// 所有金錢欄位用 Decimal(20, 2)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────
// 使用者與身分
// ───────────────────────────────────────────────

enum Role {
  PLAYER
  ADMIN
}

enum MarketType {
  D
  A
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String?
  balance      Decimal  @default(1000) @db.Decimal(20, 2)
  role         Role     @default(PLAYER)

  // 代理後台歸屬
  agentId      String?
  agent        Agent?     @relation(fields: [agentId], references: [id])
  marketType   MarketType @default(D)
  bettingLimitLevel String @default("level3")
  frozenAt     DateTime?
  disabledAt   DateTime?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bets          Bet[]
  transactions  Transaction[]
  serverSeeds   ServerSeed[]
  clientSeeds   ClientSeed[]
  minesRounds   MinesRound[]
  hiloRounds    HiLoRound[]
  towerRounds   TowerRound[]
  refreshTokens RefreshToken[]

  @@index([username])
  @@index([agentId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

// ───────────────────────────────────────────────
// 金流
// ───────────────────────────────────────────────

enum TxType {
  SIGNUP_BONUS
  BET_PLACE
  BET_WIN
  CASHOUT
  ADJUSTMENT
  REBATE
  TRANSFER_IN
  TRANSFER_OUT
}

model Transaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  type         TxType
  amount       Decimal  @db.Decimal(20, 2)
  balanceAfter Decimal  @db.Decimal(20, 2)
  betId        String?
  bet          Bet?     @relation(fields: [betId], references: [id])
  meta         Json?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([betId])
}

// ───────────────────────────────────────────────
// Provably Fair 種子
// ───────────────────────────────────────────────

model ServerSeed {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  gameCategory String
  seed         String
  seedHash     String
  isActive     Boolean   @default(true)
  nonce        Int       @default(0)
  revealedAt   DateTime?
  createdAt    DateTime  @default(now())

  bets         Bet[]

  @@index([userId, gameCategory, isActive])
}

model ClientSeed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  seed      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, isActive])
}

// ───────────────────────────────────────────────
// 下注紀錄
// ───────────────────────────────────────────────

enum BetStatus {
  PENDING
  SETTLED
  VOID
}

model Bet {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  gameId         String
  amount         Decimal    @db.Decimal(20, 2)
  multiplier     Decimal    @db.Decimal(20, 4)
  payout         Decimal    @db.Decimal(20, 2)
  profit         Decimal    @db.Decimal(20, 2)
  nonce          Int
  clientSeedUsed String
  serverSeedId   String
  serverSeed     ServerSeed @relation(fields: [serverSeedId], references: [id])
  resultData     Json
  status         BetStatus  @default(SETTLED)
  createdAt      DateTime   @default(now())
  settledAt      DateTime   @default(now())

  transactions   Transaction[]
  minesRound     MinesRound? @relation(fields: [minesRoundId], references: [id])
  minesRoundId   String?     @unique
  hiloRound      HiLoRound?  @relation(fields: [hiloRoundId], references: [id])
  hiloRoundId    String?     @unique
  towerRound     TowerRound? @relation(fields: [towerRoundId], references: [id])
  towerRoundId   String?     @unique

  @@index([userId, createdAt])
  @@index([gameId, createdAt])
}

// ───────────────────────────────────────────────
// Mines 多步驟局
// ───────────────────────────────────────────────

enum RoundStatus {
  ACTIVE
  BUSTED
  CASHED_OUT
}

model MinesRound {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  betAmount         Decimal     @db.Decimal(20, 2)
  mineCount         Int
  minePositions     Int[]
  revealed          Int[]       @default([])
  currentMultiplier Decimal     @default(1) @db.Decimal(20, 4)
  status            RoundStatus @default(ACTIVE)
  nonce             Int
  serverSeedId      String
  clientSeedUsed    String
  createdAt         DateTime    @default(now())
  finishedAt        DateTime?

  bet               Bet?

  @@index([userId, status])
}

// ───────────────────────────────────────────────
// Hi-Lo 多步驟局
// ───────────────────────────────────────────────

model HiLoRound {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  betAmount         Decimal     @db.Decimal(20, 2)
  cardIndex         Int         @default(0)
  history           Json        // [{ rank, suit }, ...]
  currentMultiplier Decimal     @default(1) @db.Decimal(20, 4)
  skipsUsed         Int         @default(0)
  status            RoundStatus @default(ACTIVE)
  nonce             Int
  serverSeedId      String
  clientSeedUsed    String
  createdAt         DateTime    @default(now())
  finishedAt        DateTime?

  bet               Bet?

  @@index([userId, status])
}

// ───────────────────────────────────────────────
// Tower 多步驟局
// ───────────────────────────────────────────────

model TowerRound {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  betAmount         Decimal     @db.Decimal(20, 2)
  difficulty        String
  safeLayout        Json        // number[][] layer of safe col indices
  picks             Int[]       @default([])
  currentLevel      Int         @default(0)
  currentMultiplier Decimal     @default(1) @db.Decimal(20, 4)
  status            RoundStatus @default(ACTIVE)
  nonce             Int
  serverSeedId      String
  clientSeedUsed    String
  createdAt         DateTime    @default(now())
  finishedAt        DateTime?

  bet               Bet?

  @@index([userId, status])
}

// ───────────────────────────────────────────────
// Crash 類共用房間
// ───────────────────────────────────────────────

enum CrashStatus {
  BETTING
  RUNNING
  CRASHED
}

model CrashRound {
  id             String      @id @default(cuid())
  gameId         String
  roundNumber    Int
  serverSeedHash String
  serverSeed     String?
  crashPoint     Decimal     @db.Decimal(10, 4)
  status         CrashStatus @default(BETTING)
  bettingEndsAt  DateTime?
  startedAt      DateTime?
  crashedAt      DateTime?
  createdAt      DateTime    @default(now())

  bets           CrashBet[]

  @@unique([gameId, roundNumber])
  @@index([gameId, createdAt])
}

model CrashBet {
  id          String     @id @default(cuid())
  roundId     String
  round       CrashRound @relation(fields: [roundId], references: [id])
  userId      String
  amount      Decimal    @db.Decimal(20, 2)
  autoCashOut Decimal?   @db.Decimal(10, 4)
  cashedOutAt Decimal?   @db.Decimal(10, 4)
  payout      Decimal    @default(0) @db.Decimal(20, 2)
  createdAt   DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([roundId])
}

model CrashRoomLease {
  gameId           String   @id
  ownerInstanceId  String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([expiresAt])
}

// ───────────────────────────────────────────────
// 代理後台：Agent 層級
// ───────────────────────────────────────────────

enum AgentStatus {
  ACTIVE
  FROZEN
  DISABLED
  DELETED
}

enum RebateMode {
  PERCENTAGE
  ALL
  NONE
}

enum AdminRole {
  SUPER_ADMIN
  AGENT
  SUB_ACCOUNT
}

model Agent {
  id                   String      @id @default(cuid())
  username             String      @unique
  passwordHash         String
  displayName          String?
  parentId             String?
  parent               Agent?      @relation("AgentTree", fields: [parentId], references: [id])
  children             Agent[]     @relation("AgentTree")
  level                Int
  marketType           MarketType  @default(D)
  balance              Decimal     @default(0) @db.Decimal(20, 2)
  commissionBalance    Decimal     @default(0) @db.Decimal(20, 2)
  commissionRate       Decimal     @default(0) @db.Decimal(5, 4)
  rebateMode           RebateMode  @default(PERCENTAGE)
  rebatePercentage     Decimal     @default(0.041) @db.Decimal(5, 4)
  maxRebatePercentage  Decimal     @default(0.041) @db.Decimal(5, 4)
  bettingLimitLevel    String      @default("level3")
  status               AgentStatus @default(ACTIVE)
  role                 AdminRole   @default(AGENT)
  notes                String?
  lastLoginAt          DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  members              User[]
  refreshTokens        AgentRefreshToken[]
  auditLogs            AuditLog[]  @relation("AuditActor")
  winLossControls      WinLossControl[] @relation("WLCOperator")
  memberWinCaps        MemberWinCapControl[] @relation("CapCreatedBy")
  memberDeposits       MemberDepositControl[] @relation("DepositCreatedBy")

  @@index([parentId])
  @@index([username])
  @@index([level])
}

model AgentRefreshToken {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([agentId])
  @@index([tokenHash])
}

// ───────────────────────────────────────────────
// 代理後台：點數轉帳（雙向紀錄）
// ───────────────────────────────────────────────

enum PointTransferType {
  AGENT_TO_AGENT
  AGENT_TO_MEMBER
  MEMBER_TO_AGENT
  CS_AGENT_TRANSFER
  CS_MEMBER_TRANSFER
  REBATE_PAYOUT
}

model PointTransfer {
  id                String            @id @default(cuid())
  type              PointTransferType
  fromType          String
  fromId            String
  toType            String
  toId              String
  amount            Decimal           @db.Decimal(20, 2)
  fromBeforeBalance Decimal           @db.Decimal(20, 2)
  fromAfterBalance  Decimal           @db.Decimal(20, 2)
  toBeforeBalance   Decimal           @db.Decimal(20, 2)
  toAfterBalance    Decimal           @db.Decimal(20, 2)
  description       String?
  operatorId        String?
  operatorType      String?
  ipAddress         String?
  createdAt         DateTime          @default(now())

  @@index([fromType, fromId, createdAt])
  @@index([toType, toId, createdAt])
  @@index([operatorId, createdAt])
}

// ───────────────────────────────────────────────
// 代理後台：控制（輸贏 / 封頂 / 入金 / 代理線）
// ───────────────────────────────────────────────

enum ControlMode {
  NORMAL
  AGENT_LINE
  SINGLE_MEMBER
  AUTO_DETECT
}

model WinLossControl {
  id                String      @id @default(cuid())
  controlMode       ControlMode
  targetType        String?
  targetId          String?
  targetUsername    String?
  controlPercentage Decimal     @default(50) @db.Decimal(5, 2)
  winControl        Boolean     @default(false)
  lossControl       Boolean     @default(false)
  isActive          Boolean     @default(true)
  startPeriod       String?
  operatorId        String?
  operator          Agent?      @relation("WLCOperator", fields: [operatorId], references: [id])
  operatorUsername  String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([isActive, controlMode])
  @@index([targetType, targetId])
}

model MemberWinCapControl {
  id               String   @id @default(cuid())
  memberId         String
  memberUsername   String   @unique
  agentId          String
  creator          Agent    @relation("CapCreatedBy", fields: [agentId], references: [id])
  winCapAmount     Decimal  @db.Decimal(20, 2)
  controlWinRate   Decimal  @default(0.70) @db.Decimal(5, 4)
  triggerThreshold Decimal  @default(0.80) @db.Decimal(5, 4)
  currentGameDay   String
  todayWinAmount   Decimal  @default(0) @db.Decimal(20, 2)
  todayBetCount    Int      @default(0)
  isActive         Boolean  @default(true)
  isCapped         Boolean  @default(false)
  notes            String?
  operatorUsername String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive, isCapped])
}

model MemberDepositControl {
  id               String   @id @default(cuid())
  memberId         String
  memberUsername   String
  agentId          String
  creator          Agent    @relation("DepositCreatedBy", fields: [agentId], references: [id])
  depositAmount    Decimal  @db.Decimal(20, 2)
  targetProfit     Decimal  @db.Decimal(20, 2)
  startBalance     Decimal  @db.Decimal(20, 2)
  controlWinRate   Decimal  @default(0.70) @db.Decimal(5, 4)
  isActive         Boolean  @default(true)
  isCompleted      Boolean  @default(false)
  startPeriod      String?
  notes            String?
  operatorUsername String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([memberUsername, isActive])
}

model AgentLineWinCap {
  id               String   @id @default(cuid())
  agentId          String   @unique
  agentUsername    String
  dailyCap         Decimal  @db.Decimal(20, 2)
  todayWinAmount   Decimal  @default(0) @db.Decimal(20, 2)
  currentGameDay   String
  isActive         Boolean  @default(true)
  notes            String?
  operatorUsername String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ───────────────────────────────────────────────
// 公告管理（跑馬燈 / 彈窗）
// ───────────────────────────────────────────────

model Announcement {
  id        String    @id @default(cuid())
  content   String    @db.Text
  /// 'marquee' 跑馬燈 / 'popup' 彈窗
  kind      String    @default("marquee")
  /// 優先級，數字大越前面
  priority  Int       @default(0)
  /// 是否啟用
  isActive  Boolean   @default(true)
  /// 顯示起始時間（null = 立即）
  startsAt  DateTime?
  /// 顯示結束時間（null = 永久）
  endsAt    DateTime?
  createdBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive, kind])
  @@index([priority])
}

// 控制介入紀錄（可審計）
model WinLossControlLogs {
  id             String   @id @default(cuid())
  controlId      String
  betId          String?
  userId         String
  gameId         String
  originalResult Json
  finalResult    Json
  flipReason     String
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([controlId, createdAt])
}

// ───────────────────────────────────────────────
// 代理後台：審計日誌
// ───────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  actorId       String?
  actor         Agent?   @relation("AuditActor", fields: [actorId], references: [id])
  actorType     String
  actorUsername String
  action        String
  targetType    String?
  targetId      String?
  oldValues     Json?
  newValues     Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
}
